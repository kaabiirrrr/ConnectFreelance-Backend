# ============================================================
# Connectfreelance Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
# NODE_ENV=production   ← set this on Render/Railway

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars_here

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=https://connectfreelance.in
CLIENT_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001
# Production:
# FRONTEND_URL=https://connectfreelance.in
# BACKEND_URL=https://connect-backend-1-dm8d.onrender.com

# CORS (comma-separated, no spaces)
ALLOWED_ORIGINS=https://connectfreelance.in,https://www.connectfreelance.in,http://localhost:5173

# ── Email (Gmail SMTP) ───────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Connectfreelance <noreply@connectfreelance.in>
# Note: Use Gmail App Password (not your account password)
# https://myaccount.google.com/apppasswords

# ── Payments ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── AI (Groq) ────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Video (Agora) ────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_certificate
AGORA_CUSTOMER_ID=your_agora_customer_id
AGORA_CUSTOMER_SECRET=your_agora_customer_secret

# ── Admin ────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@connectfreelance.in

# ── 2FA ──────────────────────────────────────────────────────
2FA_ISSUER_NAME=Connectfreelance

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ── File Upload ──────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
