const supabase = require('../../supabase/adminClient');
const logger = require('../../utils/logger');

exports.getDashboardOverview = async (req, res, next) => {
    try {
        // Core queries — all tables guaranteed to exist
        const [
            { count: totalUsers },
            { count: totalClients },
            { count: totalFreelancers },
            { count: totalJobs },
            { count: totalProposals },
            { count: activeContracts },
            { count: completedContracts },
            { count: pendingDisputes },
            { count: pendingVerifications },
            { data: paymentsData },
            { count: recentActivityCount },
            { count: onlineUsers },
            { count: bannedUsers },
            { count: flaggedUsers }
        ] = await Promise.all([
            supabase.from('profiles').select('*', { count: 'exact', head: true }),
            supabase.from('profiles').select('*', { count: 'exact', head: true }).eq('role', 'CLIENT'),
            supabase.from('profiles').select('*', { count: 'exact', head: true }).eq('role', 'FREELANCER'),
            supabase.from('jobs').select('*', { count: 'exact', head: true }),
            supabase.from('proposals').select('*', { count: 'exact', head: true }),
            supabase.from('contracts').select('*', { count: 'exact', head: true }).eq('status', 'ACTIVE'),
            supabase.from('contracts').select('*', { count: 'exact', head: true }).eq('status', 'COMPLETED'),
            supabase.from('disputes').select('*', { count: 'exact', head: true }).eq('status', 'OPEN'),
            supabase.from('profiles').select('*', { count: 'exact', head: true }).ilike('verification_status', 'pending'),
            supabase.from('payments').select('amount').in('status', ['escrow', 'released', 'requires_capture', 'succeeded']),
            supabase.from('user_activity_logs').select('*', { count: 'exact', head: true }).gte('created_at', new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString()),
            supabase.from('profiles').select('*', { count: 'exact', head: true }).eq('online_for_messages', true),
            supabase.from('profiles').select('*', { count: 'exact', head: true }).eq('is_banned', true),
            supabase.from('profiles').select('*', { count: 'exact', head: true }).eq('is_restricted', true),
        ]);

        // Optional tables — safe fallback if they don't exist in this deployment
        let connectsPurchased = 0;
        let pendingWithdrawals = 0;
        let totalWithdrawalAmount = 0;
        let approvedWithdrawals = 0;

        const [cpResult, wrResult] = await Promise.allSettled([
            supabase.from('connects_transactions').select('*', { count: 'exact', head: true }).eq('type', 'purchase'),
            supabase.from('withdrawal_requests').select('amount, status').limit(1000)
        ]);
        if (cpResult.status === 'fulfilled' && !cpResult.value.error) {
            connectsPurchased = cpResult.value.count || 0;
        }
        if (wrResult.status === 'fulfilled' && !wrResult.value.error && wrResult.value.data) {
            const wr = wrResult.value.data;
            totalWithdrawalAmount = wr.reduce((acc, w) => acc + Number(w.amount || 0), 0);
            approvedWithdrawals = wr.filter(w => w.status === 'approved').length;
            pendingWithdrawals = wr.filter(w => w.status === 'pending').length;
        }

        const systemStatus = 'OPERATIONAL';

        // Fetch real commission if available
        const { data: commissionSettings } = await supabase
            .from('platform_settings')
            .select('setting_value')
            .eq('setting_key', 'commission_percentage')
            .maybeSingle();

        const commissionRate = commissionSettings ? parseFloat(commissionSettings.setting_value) / 100 : 0.10;
        
        // Ensure totalEarnings is a number and platformCommission is 10% of it
        const totalEarnings = Number(paymentsData?.reduce((acc, curr) => acc + Number(curr.amount), 0) || 0);
        const platformCommission = Number((totalEarnings * commissionRate).toFixed(2));


        // Fetch user growth data (last 6 months)
        const sixMonthsAgo = new Date();
        sixMonthsAgo.setMonth(sixMonthsAgo.getMonth() - 6);
        
        const { data: userGrowthData } = await supabase
            .from('profiles')
            .select('created_at, role')
            .gte('created_at', sixMonthsAgo.toISOString())
            .order('created_at', { ascending: true });

        // Aggregate by month (initialize last 6 months with role counts)
        const userGrowthMap = new Map();
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        
        for (let i = 5; i >= 0; i--) {
            const d = new Date();
            d.setMonth(d.getMonth() - i);
            const key = `${months[d.getMonth()]} ${d.getFullYear()}`;
            userGrowthMap.set(key, { name: key, total: 0, freelancers: 0, clients: 0 });
        }
        
        userGrowthData?.forEach(user => {
            const date = new Date(user.created_at);
            const key = `${months[date.getMonth()]} ${date.getFullYear()}`;
            if (userGrowthMap.has(key)) {
                const stats = userGrowthMap.get(key);
                stats.total += 1;
                if (user.role === 'FREELANCER') stats.freelancers += 1;
                if (user.role === 'CLIENT') stats.clients += 1;
            }
        });

        const userGrowth = Array.from(userGrowthMap.values());


        // Fetch revenue data (last 30 days)
        const thirtyDaysAgo = new Date();
        thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 29);
        thirtyDaysAgo.setHours(0, 0, 0, 0);
        
        const { data: revenueDataRaw } = await supabase
            .from('payments')
            .select('amount, created_at')
            .gte('created_at', thirtyDaysAgo.toISOString())
            .in('status', ['released', 'escrow', 'requires_capture', 'succeeded'])
            .order('created_at', { ascending: true });

        // Aggregate by day (last 30 days)
        const revenueMap = new Map();
        for (let i = 29; i >= 0; i--) {
            const d = new Date();
            d.setDate(d.getDate() - i);
            const key = `${d.getDate()} ${months[d.getMonth()]}`;
            revenueMap.set(key, 0);
        }
        
        revenueDataRaw?.forEach(payment => {
            const date = new Date(payment.created_at);
            const key = `${date.getDate()} ${months[date.getMonth()]}`;
            if (revenueMap.has(key)) {
                revenueMap.set(key, revenueMap.get(key) + Number(payment.amount));
            }
        });

        const revenueGrowth = Array.from(revenueMap.entries()).map(([name, amount]) => ({ name, amount: Number(amount.toFixed(2)) }));

        // 3. User Activity Analytics (Page Visits/Features) - Aggregated in SQL to bypass 1000-row limits
        const { data: pageVisitsAggregated } = await supabase
            .rpc('get_page_visit_stats'); // Use a custom RPC for speed/correctness if possible, or fallback to direct query

        // If RPC doesn't exist, we'll use a direct group by query
        let topPages = [];
        let topFeatures = [];

        try {
            const { data: pgData } = await supabase
                .from('user_activity_logs')
                .select('page_path')
                .eq('action_type', 'visit');
            
            // Note: If data is large, this still hits limits. 
            // Better to use a raw SQL query via a hidden RPC or just increase limit for now if we can't add RPC.
            // But since I can't easily add RPCs here, I'll increase the limit to 10,000 as a quick fix.
            const { data: pageVisits } = await supabase
                .from('user_activity_logs')
                .select('page_path')
                .eq('action_type', 'visit')
                .limit(10000);

            const pageTitleMap = {
                '/': 'Landing',
                '/find-work': 'Marketplace',
                '/find-freelancers': 'Talent',
                '/messages': 'Messaging',
                '/client/dashboard': 'Client',
                '/freelancer/dashboard': 'Freelancer',
                '/admin/dashboard': 'Admin',
                '/profile': 'Profile',
                '/settings': 'Settings'
            };

            const pageMap = {};
            pageVisits?.forEach(v => {
                const rawPath = v.page_path || 'unknown';
                const page = pageTitleMap[rawPath] || (rawPath.length > 1 ? rawPath.split('/')[1].charAt(0).toUpperCase() + rawPath.split('/')[1].slice(1) : 'Home');
                pageMap[page] = (pageMap[page] || 0) + 1;
            });

            topPages = Object.entries(pageMap)
                .map(([page, count]) => ({ page, count }))
                .sort((a, b) => b.count - a.count)
                .slice(0, 5);

            const { data: featureUsage } = await supabase
                .from('user_activity_logs')
                .select('feature_name')
                .not('feature_name', 'is', null)
                .limit(10000);

            const featureMap = {};
            featureUsage?.forEach(f => {
                // Normalize feature names (lowercase and remove underscores)
                let name = f.feature_name.toLowerCase().replace(/_/g, ' ');
                name = name.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
                
                // Specific merges
                if (name === 'Proposal Submission') name = 'Submit Proposal';
                
                featureMap[name] = (featureMap[name] || 0) + 1;
            });
            
            topFeatures = Object.entries(featureMap)
                .map(([name, value]) => ({ name, value }))
                .sort((a, b) => b.value - a.value)
                .slice(0, 6);

        } catch (err) {
            console.error("Error in aggregation", err);
        }

        // Top freelancers by contracts
        const { data: topFreelancersRaw } = await supabase
            .from('contracts')
            .select('freelancer_id, profiles!contracts_freelancer_id_fkey(name, avatar_url)')
            .eq('status', 'COMPLETED')
            .limit(500);

        const freelancerMap = {};
        topFreelancersRaw?.forEach(c => {
            const id = c.freelancer_id;
            if (!id) return;
            if (!freelancerMap[id]) freelancerMap[id] = { id, name: c.profiles?.name || 'Unknown', avatar: c.profiles?.avatar_url, count: 0 };
            freelancerMap[id].count++;
        });
        const topFreelancers = Object.values(freelancerMap).sort((a, b) => b.count - a.count).slice(0, 5);

        // Top clients by jobs posted
        const { data: topClientsRaw } = await supabase
            .from('jobs')
            .select('client_id, profiles!jobs_client_id_fkey(name, avatar_url)')
            .limit(500);

        const clientMap = {};
        topClientsRaw?.forEach(j => {
            const id = j.client_id;
            if (!id) return;
            if (!clientMap[id]) clientMap[id] = { id, name: j.profiles?.name || 'Unknown', avatar: j.profiles?.avatar_url, count: 0 };
            clientMap[id].count++;
        });
        const topClients = Object.values(clientMap).sort((a, b) => b.count - a.count).slice(0, 5);

        // User acquisition funnel
        const { count: profilesCompleted } = await supabase
            .from('profiles')
            .select('*', { count: 'exact', head: true })
            .not('title', 'is', null);

        const { count: usersWithContracts } = await supabase
            .from('contracts')
            .select('freelancer_id', { count: 'exact', head: true });

        res.status(200).json({
            success: true,
            data: {
                overview: {
                    totalUsers,
                    totalClients,
                    totalFreelancers,
                    totalJobs,
                    activeContracts,
                    completedContracts: completedContracts || 0,
                    pendingDisputes,
                    pendingVerifications,
                    totalProposals,
                    totalEarnings,
                    platformCommission,
                    recentActivityCount,
                    onlineUsers: onlineUsers || 0,
                    bannedUsers: bannedUsers || 0,
                    flaggedUsers: flaggedUsers || 0,
                    connectsPurchased: connectsPurchased || 0,
                    pendingWithdrawals: pendingWithdrawals || 0,
                    totalWithdrawalAmount,
                    approvedWithdrawals,
                    systemStatus
                },
                userGrowth,
                revenueGrowth,
                topPages,
                topFeatures,
                topFreelancers,
                topClients,
                funnel: {
                    registered: totalUsers || 0,
                    profileCompleted: profilesCompleted || 0,
                    proposalSubmitted: totalProposals || 0,
                    contractStarted: (activeContracts || 0) + (completedContracts || 0)
                }
            }
        });
    } catch (error) {
        logger.error('[AdminAnalytics] Error', error);
        next(error);
    }
};

exports.getAdminActivityStats = async (req, res, next) => {
    try {
        // 1. Get Actions per Admin (from admin_logs)
        const { data: actionsPerAdminRaw } = await supabase
            .from('admin_logs')
            .select('admin_email');

        const adminActionMap = {};
        actionsPerAdminRaw?.forEach(log => {
            const email = log.admin_email || 'Unknown';
            adminActionMap[email] = (adminActionMap[email] || 0) + 1;
        });

        const actionsPerAdmin = Object.entries(adminActionMap)
            .map(([name, value]) => ({ name: name.split('@')[0], email: name, value }))
            .sort((a, b) => b.value - a.value)
            .slice(0, 10);

        // 2. Get Top Action Types (What they are doing)
        const { data: actionTypesRaw } = await supabase
            .from('admin_logs')
            .select('action_type');

        const typeMap = {};
        actionTypesRaw?.forEach(log => {
            const type = log.action_type || 'Other';
            typeMap[type] = (typeMap[type] || 0) + 1;
        });

        const actionDistribution = Object.entries(typeMap)
            .map(([name, value]) => ({ name, value }))
            .sort((a, b) => b.value - a.value);

        // 3. Get Feature Engagement for Admins (Where they invest time)
        // First get all admin IDs
        const { data: adminIds } = await supabase.from('admins').select('id');
        const ids = adminIds?.map(a => a.id) || [];

        const { data: adminActivityRaw } = await supabase
            .from('user_activity_logs')
            .select('feature_name, page_path')
            .in('user_id', ids);

        const featureEngagementMap = {};
        adminActivityRaw?.forEach(log => {
            const feature = log.feature_name || (log.page_path ? log.page_path.split('/')[2] : 'General');
            if (feature) {
                const formattedFeature = feature.charAt(0).toUpperCase() + feature.slice(1);
                featureEngagementMap[formattedFeature] = (featureEngagementMap[formattedFeature] || 0) + 1;
            }
        });

        const featureEngagement = Object.entries(featureEngagementMap)
            .map(([name, value]) => ({ name, value }))
            .sort((a, b) => b.value - a.value)
            .slice(0, 8);

        // 4. Get Activity Timeline (Last 7 days)
        const sevenDaysAgo = new Date();
        sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

        const { data: timelineRaw } = await supabase
            .from('admin_logs')
            .select('created_at')
            .gte('created_at', sevenDaysAgo.toISOString())
            .order('created_at', { ascending: true });

        const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
        const timelineMap = new Map();
        
        for (let i = 6; i >= 0; i--) {
            const d = new Date();
            d.setDate(d.getDate() - i);
            const key = `${d.getDate()} ${days[d.getDay()]}`;
            timelineMap.set(key, 0);
        }

        timelineRaw?.forEach(log => {
            const date = new Date(log.created_at);
            const key = `${date.getDate()} ${days[date.getDay()]}`;
            if (timelineMap.has(key)) {
                timelineMap.set(key, timelineMap.get(key) + 1);
            }
        });

        const activityTimeline = Array.from(timelineMap.entries()).map(([name, value]) => ({ name, value }));

        // 5. Get Top Contributor for the Primary Workload
        const primaryWorkloadName = actionDistribution[0]?.name;
        let primaryWorkloadAdmin = 'System';
        if (primaryWorkloadName) {
            const { data: workloadAdminRaw } = await supabase
                .from('admin_logs')
                .select('admin_email')
                .eq('action_type', primaryWorkloadName);
            
            const workloadAdminMap = {};
            workloadAdminRaw?.forEach(log => {
                workloadAdminMap[log.admin_email] = (workloadAdminMap[log.admin_email] || 0) + 1;
            });
            const topEmail = Object.entries(workloadAdminMap)
                .sort((a, b) => b[1] - a[1])[0]?.[0];
            primaryWorkloadAdmin = topEmail ? topEmail.split('@')[0] : 'System';
        }

        // 6. Get Top Contributor for Most Investigated Feature
        const topFeatureName = featureEngagement[0]?.name;
        let topFeatureAdmin = 'Team';
        if (topFeatureName) {
            // Need to join user_activity_logs with admins table or use ids
            const { data: featureAdminRaw } = await supabase
                .from('user_activity_logs')
                .select('user_id')
                .eq('feature_name', topFeatureName)
                .in('user_id', ids);

            const featureAdminMap = {};
            featureAdminRaw?.forEach(log => {
                featureAdminMap[log.user_id] = (featureAdminMap[log.user_id] || 0) + 1;
            });
            const topId = Object.entries(featureAdminMap)
                .sort((a, b) => b[1] - a[1])[0]?.[0];
            
            if (topId) {
                const { data: adminUser } = await supabase.from('admins').select('name').eq('id', topId).maybeSingle();
                topFeatureAdmin = adminUser?.name || 'Admin';
            }
        }

        res.status(200).json({
            success: true,
            data: {
                actionsPerAdmin,
                actionDistribution,
                featureEngagement,
                activityTimeline,
                attribution: {
                    primaryWorkloadAdmin,
                    topFeatureAdmin
                }
            }
        });
    } catch (error) {
        logger.error('[AdminActivityAnalytics] Error', error);
        next(error);
    }
};

exports.getPlatformActivity = async (req, res, next) => {
    try {
        const { limit = 10 } = req.query;

        // Fetch real activities from multiple tables
        const [
            { data: newUsers },
            { data: newJobs },
            { data: newProposals },
            { data: adminLogs }
        ] = await Promise.all([
            supabase.from('profiles').select('id, name, role, created_at').order('created_at', { ascending: false }).limit(limit),
            supabase.from('jobs').select('id, title, created_at').order('created_at', { ascending: false }).limit(limit),
            supabase.from('proposals').select('id, job_id, created_at, jobs(title)').order('created_at', { ascending: false }).limit(limit),
            supabase.from('admin_logs').select('id, description, created_at, admin_email').order('created_at', { ascending: false }).limit(limit)
        ]);

        // Transform into a unified format
        const activities = [];

        newUsers?.forEach(user => {
            activities.push({
                id: `user-${user.id}`,
                type: 'USER_SIGNUP',
                description: `New ${user.role?.toLowerCase() || 'user'} joined: ${user.name || 'Anonymous'}`,
                created_at: user.created_at,
                admin_email: 'System'
            });
        });

        newJobs?.forEach(job => {
            activities.push({
                id: `job-${job.id}`,
                type: 'JOB_POSTED',
                description: `New job posted: ${job.title}`,
                created_at: job.created_at,
                admin_email: 'Marketplace'
            });
        });

        newProposals?.forEach(prop => {
            activities.push({
                id: `prop-${prop.id}`,
                type: 'PROPOSAL_SUBMITTED',
                description: `New proposal submitted for: ${prop.jobs?.title || 'a job'}`,
                created_at: prop.created_at,
                admin_email: 'Marketplace'
            });
        });

        adminLogs?.forEach(log => {
            activities.push({
                id: `log-${log.id}`,
                type: 'ADMIN_ACTION',
                description: log.description,
                created_at: log.created_at,
                admin_email: log.admin_email?.split('@')[0] || 'Admin'
            });
        });

        // Sort by date descending and limit
        const unified = activities
            .sort((a, b) => new Date(b.created_at) - new Date(a.created_at))
            .slice(0, limit);

        res.status(200).json({
            success: true,
            data: unified
        });
    } catch (error) {
        logger.error('[PlatformActivity] Error', error);
        next(error);
    }
};

// ─── Feature Error Heatmap ────────────────────────────────────────────────────
// GET /api/admin/analytics/error-heatmap
exports.getErrorHeatmap = async (req, res, next) => {
    try {
        const { data, error } = await supabase
            .from('error_logs')
            .select('feature, status_code, created_at')
            .gte('created_at', new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString())
            .limit(5000);

        if (error) return res.status(200).json({ success: true, data: [] });

        const featureMap = {};
        data?.forEach(e => {
            const f = e.feature || 'Unknown';
            if (!featureMap[f]) featureMap[f] = { feature: f, count: 0, errors: [] };
            featureMap[f].count++;
        });

        const heatmap = Object.values(featureMap)
            .sort((a, b) => b.count - a.count)
            .slice(0, 10);

        res.status(200).json({ success: true, data: heatmap });
    } catch (err) {
        logger.error('[ErrorHeatmap]', err);
        res.status(200).json({ success: true, data: [] });
    }
};

// ─── Recent Error Feed ────────────────────────────────────────────────────────
// GET /api/admin/analytics/recent-errors
exports.getRecentErrors = async (req, res, next) => {
    try {
        const { data, error } = await supabase
            .from('error_logs')
            .select('id, user_email, feature, endpoint, error_message, status_code, created_at')
            .order('created_at', { ascending: false })
            .limit(20);

        if (error) return res.status(200).json({ success: true, data: [] });
        res.status(200).json({ success: true, data: data || [] });
    } catch (err) {
        logger.error('[RecentErrors]', err);
        res.status(200).json({ success: true, data: [] });
    }
};

// ─── User Session Tracker ─────────────────────────────────────────────────────
// GET /api/admin/analytics/sessions
exports.getUserSessions = async (req, res, next) => {
    try {
        const oneDayAgo = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();

        // Step 1: Get recent activity logs (no join — avoids FK issues)
        const { data: logs, error } = await supabase
            .from('user_activity_logs')
            .select('user_id, page_path, created_at')
            .gte('created_at', oneDayAgo)
            .not('user_id', 'is', null)
            .order('created_at', { ascending: false })
            .limit(1000);

        if (error) {
            logger.warn('[UserSessions] activity_logs query failed:', error.message);
            return res.status(200).json({ success: true, data: [] });
        }

        // Step 2: Group by user_id
        const userMap = {};
        (logs || []).forEach(log => {
            const uid = log.user_id;
            if (!uid) return;
            if (!userMap[uid]) {
                userMap[uid] = {
                    user_id: uid,
                    last_active: log.created_at,
                    current_page: log.page_path,
                    session_count: 0,
                    pages_visited: []
                };
            }
            userMap[uid].session_count++;
            if (log.page_path && !userMap[uid].pages_visited.includes(log.page_path)) {
                userMap[uid].pages_visited.push(log.page_path);
            }
        });

        const userIds = Object.keys(userMap);
        if (userIds.length === 0) return res.status(200).json({ success: true, data: [] });

        // Step 3: Fetch profiles separately
        const { data: profiles } = await supabase
            .from('profiles')
            .select('user_id, name, avatar_url, role')
            .in('user_id', userIds.slice(0, 100));

        const profileMap = {};
        (profiles || []).forEach(p => { profileMap[p.user_id] = p; });

        // Step 4: Merge
        const sessions = Object.values(userMap)
            .map(u => ({
                ...u,
                name: profileMap[u.user_id]?.name || 'Unknown',
                avatar: profileMap[u.user_id]?.avatar_url || null,
                role: profileMap[u.user_id]?.role || 'USER',
            }))
            .sort((a, b) => new Date(b.last_active) - new Date(a.last_active))
            .slice(0, 30);

        res.status(200).json({ success: true, data: sessions });
    } catch (err) {
        logger.error('[UserSessions]', err);
        res.status(200).json({ success: true, data: [] });
    }
};

// ─── User Journey Map ─────────────────────────────────────────────────────────
// GET /api/admin/analytics/user-journey/:userId
exports.getUserJourney = async (req, res, next) => {
    try {
        const { userId } = req.params;

        const [journeyResult, profileResult, errorsResult] = await Promise.allSettled([
            supabase.from('user_activity_logs')
                .select('page_path, feature_name, action_type, created_at')
                .eq('user_id', userId)
                .order('created_at', { ascending: false })
                .limit(50),
            supabase.from('profiles')
                .select('name, avatar_url, role, email, created_at, is_banned, is_restricted')
                .eq('user_id', userId)
                .maybeSingle(),
            supabase.from('error_logs')
                .select('feature, error_message, status_code, created_at')
                .eq('user_id', userId)
                .order('created_at', { ascending: false })
                .limit(20)
        ]);

        res.status(200).json({
            success: true,
            data: {
                profile: profileResult.value?.data || null,
                journey: journeyResult.value?.data || [],
                errors: errorsResult.value?.data || []
            }
        });
    } catch (err) {
        logger.error('[UserJourney]', err);
        res.status(200).json({ success: true, data: { profile: null, journey: [], errors: [] } });
    }
};

// ─── Stale Users ──────────────────────────────────────────────────────────────
// GET /api/admin/analytics/stale-users
exports.getStaleUsers = async (req, res, next) => {
    try {
        const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();

        // Users registered more than 7 days ago with no title (incomplete profile)
        const { data: allUsers, error } = await supabase
            .from('profiles')
            .select('user_id, name, email, avatar_url, role, created_at')
            .lt('created_at', sevenDaysAgo)
            .order('created_at', { ascending: false })
            .limit(100);

        if (error) {
            logger.warn('[StaleUsers] query failed:', error.message);
            return res.status(200).json({ success: true, data: [] });
        }

        // Filter: no title set (incomplete profile) — works for both roles
        const stale = (allUsers || [])
            .map(u => ({
                ...u,
                days_since_registration: Math.floor((Date.now() - new Date(u.created_at)) / (1000 * 60 * 60 * 24))
            }))
            .slice(0, 50);

        res.status(200).json({ success: true, data: stale });
    } catch (err) {
        logger.error('[StaleUsers]', err);
        res.status(200).json({ success: true, data: [] });
    }
};

// ─── Drop-off Points ──────────────────────────────────────────────────────────
// GET /api/admin/analytics/dropoffs
exports.getDropoffPoints = async (req, res, next) => {
    try {
        const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();

        const [proposalStarts, proposalDone, paymentStarts, paymentDone, profileStarts, profileDone] = await Promise.allSettled([
            supabase.from('user_activity_logs').select('*', { count: 'exact', head: true }).eq('feature_name', 'proposal_view').gte('created_at', sevenDaysAgo),
            supabase.from('proposals').select('*', { count: 'exact', head: true }).gte('created_at', sevenDaysAgo),
            supabase.from('user_activity_logs').select('*', { count: 'exact', head: true }).eq('feature_name', 'payment_view').gte('created_at', sevenDaysAgo),
            supabase.from('payments').select('*', { count: 'exact', head: true }).gte('created_at', sevenDaysAgo),
            supabase.from('user_activity_logs').select('*', { count: 'exact', head: true }).eq('feature_name', 'profile_edit').gte('created_at', sevenDaysAgo),
            supabase.from('profiles').select('*', { count: 'exact', head: true }).not('title', 'is', null).gte('created_at', sevenDaysAgo),
        ]);

        const getCount = (r) => r.status === 'fulfilled' ? (r.value?.count || 0) : 0;

        const dropoffs = [
            { flow: 'Proposal Submit', started: getCount(proposalStarts), completed: getCount(proposalDone) },
            { flow: 'Payment', started: getCount(paymentStarts), completed: getCount(paymentDone) },
            { flow: 'Profile Setup', started: getCount(profileStarts), completed: getCount(profileDone) },
        ].map(d => ({
            ...d,
            dropped: Math.max(0, d.started - d.completed),
            dropRate: d.started > 0 ? Math.round(((d.started - d.completed) / d.started) * 100) : 0
        }));

        res.status(200).json({ success: true, data: dropoffs });
    } catch (err) {
        logger.error('[Dropoffs]', err);
        res.status(200).json({ success: true, data: [] });
    }
};

// ─── Per-User Activity Inspector ──────────────────────────────────────────────
// GET /api/admin/analytics/user-inspector?search=email_or_name
exports.getUserInspector = async (req, res, next) => {
    try {
        const { search } = req.query;
        if (!search || !search.trim()) return res.status(200).json({ success: true, data: null });

        const term = search.trim();
        logger.info(`[UserInspector] Searching for: "${term}"`);

        // 1. Try to find user — run name and email searches separately to avoid
        //    PostgREST .or() parsing issues with special chars like @ and .
        let profile = null;

        // Search by email first (exact match preferred)
        const { data: byEmail } = await supabase
            .from('profiles')
            .select('user_id, name, email, avatar_url, role, created_at, updated_at, is_banned, is_restricted, warning_count, trust_score, title')
            .ilike('email', `%${term}%`)
            .limit(1);

        if (byEmail && byEmail.length > 0) {
            profile = byEmail[0];
            logger.info(`[UserInspector] Found by email: ${profile.user_id}`);
        }

        // If not found by email, search by name
        if (!profile) {
            const { data: byName } = await supabase
                .from('profiles')
                .select('user_id, name, email, avatar_url, role, created_at, updated_at, is_banned, is_restricted, warning_count, trust_score, title')
                .ilike('name', `%${term}%`)
                .limit(1);

            if (byName && byName.length > 0) {
                profile = byName[0];
                logger.info(`[UserInspector] Found by name: ${profile.user_id}`);
            }
        }

        // If still not found, try auth.users (email may not be synced to profiles)
        if (!profile) {
            // Try exact email lookup via auth admin API
            let authUser = null;
            try {
                const { data: authData } = await supabase.auth.admin.getUserByEmail(term);
                if (authData?.user) authUser = authData.user;
            } catch (_) {
                // getUserByEmail may not exist on older SDK versions — fall back to listUsers
                try {
                    const { data: authUsers } = await supabase.auth.admin.listUsers({ perPage: 1000 });
                    authUser = (authUsers?.users || []).find(u =>
                        u.email?.toLowerCase().includes(term.toLowerCase())
                    ) || null;
                } catch (__) { /* skip */ }
            }

            if (authUser) {
                // Try to get their profile by user_id
                const { data: profileById } = await supabase
                    .from('profiles')
                    .select('user_id, name, email, avatar_url, role, created_at, updated_at, is_banned, is_restricted, warning_count, trust_score, title')
                    .eq('user_id', authUser.id)
                    .maybeSingle();

                if (profileById) {
                    profile = { ...profileById, email: profileById.email || authUser.email };
                } else {
                    // User exists in auth but has no profile yet
                    profile = {
                        user_id: authUser.id,
                        name: authUser.user_metadata?.name || authUser.email?.split('@')[0] || 'Unknown',
                        email: authUser.email,
                        avatar_url: null,
                        role: 'UNKNOWN',
                        created_at: authUser.created_at,
                        updated_at: authUser.updated_at,
                        is_banned: false,
                        is_restricted: false,
                        warning_count: 0,
                        trust_score: null,
                        title: null
                    };
                }
            }
        }

        if (!profile) {
            logger.warn(`[UserInspector] No user found for search: "${term}"`);
            return res.status(200).json({ success: true, data: null });
        }

        const userId = profile.user_id;

        // 2. Fetch journey, errors, contracts in parallel
        const [journeyResult, errorsResult, contractsResult] = await Promise.allSettled([
            supabase.from('user_activity_logs')
                .select('page_path, feature_name, action_type, created_at')
                .eq('user_id', userId)
                .order('created_at', { ascending: false })
                .limit(30),
            supabase.from('error_logs')
                .select('feature, endpoint, error_message, status_code, created_at')
                .eq('user_id', userId)
                .order('created_at', { ascending: false })
                .limit(20),
            supabase.from('contracts')
                .select('id, status, created_at')
                .or(`freelancer_id.eq.${userId},client_id.eq.${userId}`)
                .order('created_at', { ascending: false })
                .limit(10)
        ]);

        // 3. Compute risk score
        const errorCount = errorsResult.value?.data?.length || 0;
        const warningCount = profile.warning_count || 0;
        const riskScore = Math.min(100, Math.round(
            (profile.is_banned ? 80 : 0) +
            (profile.is_restricted ? 40 : 0) +
            (warningCount * 10) +
            (errorCount * 2)
        ));

        res.status(200).json({
            success: true,
            data: {
                profile,
                journey: journeyResult.value?.data || [],
                errors: errorsResult.value?.data || [],
                contracts: contractsResult.value?.data || [],
                riskScore
            }
        });
    } catch (err) {
        logger.error('[UserInspector]', err);
        res.status(200).json({ success: true, data: null });
    }
};
